generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model UserProfile {
  id                  String   @id @default(cuid())
  clerkUserId         String   @unique
  name                String?
  lifeStage           String?
  currentSituation    String?
  biggestChallenge    String?
  careerGoals         String?
  financialGoals      String?
  healthGoals         String?
  personalGrowthGoals String?
  futureVision        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  blueprints        LifeBlueprint[]
  goals             Goal[]
  habits            Habit[]
  savingsGoals      SavingsGoal[]
  financialAccounts FinancialAccount[]
  transactions      Transaction[]
  budgets           Budget[]
  netWorthSnapshots NetWorthSnapshot[]
  jobApplications   JobApplication[]
  skills            Skill[]
  moodEntries       MoodEntry[]
}

model LifeBlueprint {
  id        String   @id @default(cuid())
  userId    String
  content   Json
  summary   String
  createdAt DateTime @default(now())

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id        String   @id @default(cuid())
  userId    String
  title     String
  category  String
  progress  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones Milestone[]
}

model Milestone {
  id        String   @id @default(cuid())
  goalId    String
  title     String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model Habit {
  id            String    @id @default(cuid())
  userId        String
  title         String
  streak        Int       @default(0)
  lastCompleted DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  habitLogs HabitLog[]
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  date      DateTime @default(now())
  completed Boolean  @default(false)

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}

model MoodEntry {
  id     String   @id @default(cuid())
  userId String
  mood   Int
  note   String?
  date   DateTime @default(now())

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model SavingsGoal {
  id            String   @id @default(cuid())
  userId        String
  title         String
  targetAmount  Float
  currentAmount Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FinancialAccount {
  id          String   @id @default(cuid())
  userId      String
  name        String
  type        String
  institution String?
  balance     Float    @default(0)
  currency    String   @default("USD")
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         UserProfile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@index([userId, isArchived])
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  accountId String?
  date      DateTime @default(now())
  merchant  String
  category  String
  amount    Float
  type      String   @default("expense")
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    UserProfile       @relation(fields: [userId], references: [id], onDelete: Cascade)
  account FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([accountId])
}

model Budget {
  id          String   @id @default(cuid())
  userId      String
  category    String
  limitAmount Float
  period      String   @default("monthly")
  month       DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, period, month])
  @@index([userId, month])
}

model NetWorthSnapshot {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @default(now())
  assets      Float    @default(0)
  liabilities Float    @default(0)
  netWorth    Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model JobApplication {
  id        String   @id @default(cuid())
  userId    String
  company   String
  role      String
  status    String   @default("applied")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Skill {
  id        String   @id @default(cuid())
  userId    String
  name      String
  level     String   @default("beginner")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
}

